# Shared / Docker Compose example values only.
# Copy to .env for docker compose. Never commit real production secrets.

# Postgres (local Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=store_rating
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_rating?schema=public

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Web (build-time for production SPA hosts)
# VITE_API_URL=https://your-api.example.com/api
