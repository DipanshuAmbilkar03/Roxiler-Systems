PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_rating?schema=public
# Comma-separated allowed origins, e.g.
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Optional: override local seed passwords (defaults used by prisma/seed.ts + e2e)
# SEED_ADMIN_PASSWORD=
# SEED_OWNER_PASSWORD=
# SEED_USER_PASSWORD=

